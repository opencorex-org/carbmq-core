CRABMQ_ENV=development
CRABMQ_JWT_SECRET=change-me
CRABMQ_DATABASE_URL=postgres://postgres:postgres@localhost:5432/crabmq?sslmode=disable
CRABMQ_BROKER_ADDR=0.0.0.0:1884
CRABMQ_METRICS_ADDR=0.0.0.0:9100
CRABMQ_API_ADDR=0.0.0.0:8080
CRABMQ_API_BROKER_ADDR=127.0.0.1:1884
CRABMQ_BROKER_METRICS_URL=http://127.0.0.1:9100/metrics
CRABMQ_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CRABMQ_RATE_LIMIT_PER_MIN=120
CRABMQ_SIM_DEVICE_COUNT=50
CRABMQ_SIM_INTERVAL=5s
